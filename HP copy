<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>住民カード</title>
    <style>
        body { background-color: #efeee7; padding: 20px; font-family: sans-serif; }
        
        .id-card { 
            background: #fff; 
            border: 3px solid #000; 
            border-radius: 20px; 
            padding: 15px; 
            max-width: 450px; 
            margin: auto; 
            box-shadow: 5px 5px 0px rgba(0,0,0,0.1);
        }

        .photo-frame img { 
            width: 100%; 
            border-radius: 10px; 
            border: 2px solid #000; 
            display: block;
        }

        .card-info { 
            margin-top: 15px; 
        }

        /* 名前とレベル行を横並びに */
        .info-top-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 5px;
        }

        .user-name { font-size: 1.6rem; font-weight: bold; margin: 0; }

        /* 項目名と星を横に並べる設定 */
        .level-badge {
            display: flex;
            align-items: center;
            gap: 8px; /* 項目名と星の間の隙間 */
            border-bottom: 2px solid #2d5a4c;
            padding-bottom: 2px;
        }

        .level-label { 
            color: #2d5a4c; 
            font-size: 1.1rem; 
            font-weight: bold; 
        }

        .stars { 
            color: #2d5a4c; 
            font-size: 1.1rem; 
            letter-spacing: 1px;
        }

        /* 線の下の詳細メッセージ */
        .level-description {
            font-size: 0.85rem;
            color: #555;
            margin-top: 8px;
            line-height: 1.4;
            text-align: right;
        }
    </style>
</head>
<body>

    <div class="id-card">
        <div class="photo-frame">
            <img src="有福温泉.JPG" alt="風景写真">
        </div>
        
        <div class="card-info">
            <div class="info-top-row">
                <p class="user-name" id="line-name">有福 太郎 様</p>
                
                <div class="level-badge">
                    <span class="level-label" id="user-level">---</span>
                    <div class="stars" id="star-display"></div>
                </div>
            </div>

            <div class="level-description" id="level-detail">
                読み込み中...
            </div>
        </div>
    </div>

    <script>
        const GAS_URL = "https://script.google.com/macros/s/AKfycbzv4YjlRJ8H6CvbKVPUk58XyxIUgBqx94Y6-z5DlSFxVkG3LQftpIT5ZF1gW8UG_VYO/exec";

        async function main() {
            try {
                const response = await fetch(GAS_URL);
                const data = await response.json();

                if (data.length > 0) {
                    // スプレッドシートの1番目のデータを参照
                    const userStatus = data[0]; 
                    
                    document.getElementById('user-level').innerText = userStatus.title; // 項目名
                    document.getElementById('level-detail').innerText = userStatus.description; // 詳細
                    
                    // 星の表示設定
                    const starCount = parseInt(userStatus.stars);
                    document.getElementById('star-display').innerText = "★".repeat(starCount) + "☆".repeat(5 - starCount);
                }
            } catch (error) {
                console.error("データ取得エラー:", error);
                document.getElementById('level-detail').innerText = "データの取得に失敗しました。";
            }
        }

        main();
    </script>
</body>
</html>